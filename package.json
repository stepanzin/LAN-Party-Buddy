{
  "name": "lan-party-buddy",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "compile": "bun build ./src/index.ts --compile --outfile build/lan-party-buddy",
    "compile:linux-x64": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile build/lan-party-buddy-linux-x64",
    "compile:linux-arm64": "bun build ./src/index.ts --compile --target=bun-linux-arm64 --outfile build/lan-party-buddy-linux-arm64",
    "compile:darwin-x64": "bun build ./src/index.ts --compile --target=bun-darwin-x64 --outfile build/lan-party-buddy-darwin-x64",
    "compile:darwin-arm64": "bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile build/lan-party-buddy-darwin-arm64",
    "compile:windows-x64": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile build/lan-party-buddy-windows-x64.exe",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64 && bun run compile:windows-x64",
    "lint": "bunx biome check src/ tests/",
    "lint:fix": "bunx biome check --write src/ tests/",
    "format": "bunx biome format src/ tests/",
    "format:fix": "bunx biome format --write src/ tests/",
    "check": "bunx biome check --write src/ tests/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "@types/react": "^19.2.14",
    "fast-check": "^4.6.0",
    "ink-testing-library": "^4.0.0",
    "lefthook": "^2.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@julusian/midi": "^3.6.1",
    "bonjour-service": "^1.3.0",
    "figlet": "^1.11.0",
    "fp-ts": "^2.16.11",
    "ink": "^6.8.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1",
    "yaml": "^2.8.3"
  }
}
